{
  "name": "@mihari/logger-node",
  "version": "0.2.0",
  "description": "Node.js client for mihari log collection",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "cd ../.. && npx vitest run --config vitest.config.ts packages/node"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "cjs",
      "esm"
    ],
    "dts": true,
    "splitting": false,
    "sourcemap": true,
    "clean": true,
    "external": [
      "@mihari/logger-core",
      "@mihari/logger-types"
    ]
  },
  "dependencies": {
    "@mihari/logger-core": "^0.2.0",
    "@mihari/logger-types": "^0.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mihari/mihari-js",
    "directory": "packages/node"
  }
}
